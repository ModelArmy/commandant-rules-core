{
  "tool": "magick",
  "tool_summary": "A comprehensive image processing tool for creating, editing, and converting images.",
  "platform": "posix",
  "platform_notes": "In ImageMagick v7, most functions previously provided by 'convert' are now part of the 'magick' command. On legacy systems using ImageMagick v6, users would typically use 'convert', 'mogrify', etc., directly.",
  "llm_confidence": "high",
  "unknown_flags": [],
  "is_multiplexer": false,
  "option_abbreviations": {},
  "rules": [
    {
      "id": "magick-mogrify-overwrite",
      "description": "The mogrify command (accessible via 'magick mogrify') modifies files in place, overwriting the original images by default.",
      "patterns": [
        {
          "pattern": "magick mogrify ...",
          "pattern_type": "argument",
          "example": "magick mogrify -resize 50% *.jpg",
          "match": {
            "args_any": [
              "mogrify"
            ]
          }
        }
      ],
      "risk_tags": [
        "writes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss",
        "data-corruption"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "all_match": false,
      "mitre_attack": [
        "T1485"
      ],
      "notes": "mogrify is fundamentally destructive as it overwrites the source files. Use 'magick' (convert) to create new files instead."
    },
    {
      "id": "magick-remote-read",
      "description": "Loading images from remote URLs can expose system information or be used for SSRF attacks.",
      "patterns": [
        {
          "pattern": "magick ... http://...",
          "pattern_type": "argument",
          "example": "magick https://example.com/image.jpg output.png",
          "match": {
            "raw_pattern": "https?://|ftp://"
          }
        }
      ],
      "risk_tags": [
        "network-egress",
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "all_match": false,
      "mitre_attack": [
        "T1105"
      ]
    },
    {
      "id": "magick-parameter-file",
      "description": "The '@filename' syntax allows reading options and arguments from a file, which can be exploited to read sensitive files or inject dangerous flags.",
      "patterns": [
        {
          "pattern": "magick ... @...",
          "pattern_type": "argument",
          "example": "magick @params.txt output.png",
          "match": {
            "raw_pattern": "@\\S+"
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "executes-code"
      ],
      "likely_consequences": [
        "unsafe-code-execution"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "all_match": false,
      "mitre_attack": [],
      "notes": "Depending on the content of the parameter file, this can trigger delegates that execute shell commands or read arbitrary files."
    },
    {
      "id": "magick-write-file",
      "description": "The -write flag explicitly writes the current image state to a specified file, potentially overwriting existing data.",
      "patterns": [
        {
          "pattern": "magick ... -write ...",
          "pattern_type": "flag",
          "example": "magick input.jpg -resize 50% -write intermediate.jpg output.png",
          "match": {
            "flags_any": [
              "-write"
            ]
          }
        }
      ],
      "risk_tags": [
        "writes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-corruption"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "all_match": false,
      "mitre_attack": [
        "T1565.001"
      ]
    }
  ],
  "default_rule": {
    "risk_tags": [
      "reads-files"
    ],
    "reversible": "yes",
    "severity": "INFO"
  }
}

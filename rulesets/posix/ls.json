{
    "tool": "ls",
    "tool_summary": "Lists directory contents with optional metadata, recursion, and symlink dereferencing.",
    "platform": "posix",
    "platform_notes": "Core flag semantics are largely consistent between GNU ls and BSD ls. Extended flags like --color and --quoting-style differ but carry no additional risk. No separate ruleset needed for either platform.",
    "llm_confidence": "high",
    "unknown_flags": [],
    "is_multiplexer": false,
    "option_abbreviations": {},
    "rules": [
        {
            "id": "ls-all",
            "description": "Lists hidden files and directories (dotfiles). These often contain sensitive configuration data or credentials, such as .env files, .ssh keys, .gnupg secrets, and .config settings that normal listings intentionally hide. Expands read scope beyond normal directory listing by exposing previously concealed entries.",
            "patterns": [
                {
                    "pattern": "ls -a $X",
                    "pattern_type": "flag",
                    "example": "ls -a /home/user",
                    "match": {
                        "flags_any": [
                            "-a",
                            "--all"
                        ]
                    }
                },
                {
                    "pattern": "ls -A $X",
                    "pattern_type": "flag",
                    "example": "ls -A ~/private",
                    "match": {
                        "flags_any": [
                            "-A",
                            "--almost-all"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "privacy-breach"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach"
            ]
        },
        {
            "id": "ls-dereference",
            "description": "Follows symlinks and displays metadata of the symlink target rather than the link itself. Symlinks placed in the target directory can redirect into protected filesystem locations (e.g. /etc, /var, /root), exposing metadata and access to files outside the intended scope.",
            "patterns": [
                {
                    "pattern": "ls -L $X",
                    "pattern_type": "flag",
                    "example": "ls -L /shared",
                    "match": {
                        "flags_any": [
                            "-L",
                            "--dereference"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "privacy-breach"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach"
            ],
            "notes": "Lower severity than ls-recursive-dereference since it does not traverse subdirectories. Risk is limited to symlinks directly placed in the target directory."
        },
        {
            "id": "ls-security-context",
            "description": "Displays SELinux security context (user:role:type:level) for each file. Exposes security policy details that could reveal the security model, label granularity, or identify files with weaker security contexts.",
            "patterns": [
                {
                    "pattern": "ls -Z $X",
                    "pattern_type": "flag",
                    "example": "ls -Z /etc",
                    "match": {
                        "flags_any": [
                            "-Z",
                            "--context"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "privacy-breach"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach",
                "computer-security-compromise"
            ]
        },
        {
            "id": "ls-recursive",
            "description": "Recursively lists all files and subdirectories within the target path and its descendants. Expands read scope far beyond the invocation directory, exposing file structure and names that may include sensitive information across the entire tree.",
            "patterns": [
                {
                    "pattern": "ls -R $X",
                    "pattern_type": "flag",
                    "example": "ls -R /etc",
                    "match": {
                        "flags_any": [
                            "-R",
                            "--recursive"
                        ]
                    }
                },
                {
                    "pattern": "ls --recursive $X",
                    "pattern_type": "flag",
                    "example": "ls --recursive ~/private",
                    "match": {
                        "flags_any": [
                            "-R",
                            "--recursive"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "recursive"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach"
            ]
        },
        {
            "id": "ls-recursive-dereference",
            "description": "Recursively follows symlinks, potentially traversing into directories and exposing contents outside the original invocation scope. A symlink placed in a recursive tree can redirect into /etc, /var, /root, or other protected locations, reading metadata and traversing into paths the operator did not directly intend to visit.",
            "all_match": true,
            "patterns": [
                {
                    "pattern": "ls -R -L $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -R -L /data",
                    "match": {
                        "flags_all": [
                            "-R",
                            "-L"
                        ]
                    }
                },
                {
                    "pattern": "ls -L -R $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -L -R /data",
                    "match": {
                        "flags_all": [
                            "-R",
                            "-L"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "recursive",
                "privacy-breach"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach"
            ]
        },
        {
            "id": "ls-long-context",
            "description": "Long listing with SELinux security context (-l -Z) combines metadata exposure (permissions, ownership, timestamps) with security context labels. This is a higher-risk combination since it reveals both detailed file attributes and security policy details simultaneously.",
            "all_match": true,
            "patterns": [
                {
                    "pattern": "ls -lZ $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -lZ /etc",
                    "match": {
                        "flags_all": [
                            "-l",
                            "-Z"
                        ]
                    }
                },
                {
                    "pattern": "ls -l --context $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -l --context /var",
                    "match": {
                        "flags_all": [
                            "-l",
                            "--context"
                        ]
                    }
                },
                {
                    "pattern": "ls -Zl $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -Zl /etc",
                    "match": {
                        "flags_all": [
                            "-l",
                            "-Z"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "privacy-breach"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach",
                "computer-security-compromise"
            ]
        },
        {
            "id": "ls-recursive-all",
            "description": "Recursively lists all files including hidden ones (-R -a). This is the worst-case read expansion: every file in the entire tree, including dotfiles with credentials and secrets.",
            "all_match": true,
            "patterns": [
                {
                    "pattern": "ls -Ra $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -Ra /home",
                    "match": {
                        "flags_all": [
                            "-R",
                            "-a"
                        ]
                    }
                },
                {
                    "pattern": "ls -aR $X",
                    "pattern_type": "flag-argument-combination",
                    "example": "ls -aR /home",
                    "match": {
                        "flags_all": [
                            "-R",
                            "-a"
                        ]
                    }
                }
            ],
            "risk_tags": [
                "reads-files",
                "recursive",
                "privacy-breach"
            ],
            "reversible": "yes",
            "severity": "WARNING",
            "likely_consequences": [
                "privacy-breach"
            ]
        }
    ],
    "default_rule": {
        "risk_tags": [
            "reads-files"
        ],
        "reversible": "yes",
        "severity": "INFO"
    }
}

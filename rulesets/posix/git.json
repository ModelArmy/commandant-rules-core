{
  "tool": "git",
  "tool_summary": "A distributed version control system for tracking changes in source code during software development.",
  "platform": "posix",
  "platform_notes": "Git behavior is consistent across POSIX platforms; no sibling ruleset is needed.",
  "llm_confidence": "high",
  "unknown_flags": [],
  "is_multiplexer": false,
  "option_abbreviations": {},
  "rules": [
    {
      "id": "git-reset-hard",
      "description": "Forcefully resets the head and index to a specific state, permanently overwriting local changes in the working directory.",
      "patterns": [
        {
          "pattern": "git reset --hard ...",
          "pattern_type": "flag-argument-combination",
          "example": "git reset --hard HEAD",
          "match": {
            "flags_any": [
              "--hard"
            ],
            "raw_pattern": "git\\s+reset\\b"
          }
        }
      ],
      "risk_tags": [
        "deletes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-clean-force",
      "description": "Forcefully removes untracked files from the working directory.",
      "patterns": [
        {
          "pattern": "git clean -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "git clean -f",
          "match": {
            "flags_any": [
              "-f",
              "--force"
            ],
            "raw_pattern": "git\\s+clean\\b"
          }
        },
        {
          "pattern": "git clean ... -d ...",
          "pattern_type": "flag-argument-combination",
          "example": "git clean -fd",
          "match": {
            "flags_any": [
              "-d"
            ],
            "raw_pattern": "git\\s+clean\\b"
          }
        }
      ],
      "risk_tags": [
        "deletes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-push-force",
      "description": "Forcefully updates the remote reference, overwriting history on the server and potentially deleting other contributors' work.",
      "patterns": [
        {
          "pattern": "git push -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "git push origin main -f",
          "match": {
            "flags_any": [
              "-f",
              "--force"
            ],
            "raw_pattern": "git\\s+push\\b"
          }
        }
      ],
      "risk_tags": [
        "writes-files",
        "irreversible",
        "network-egress"
      ],
      "likely_consequences": [
        "data-loss",
        "data-corruption"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-branch-delete-force",
      "description": "Deletes a local branch regardless of whether it has been merged into its upstream branch.",
      "patterns": [
        {
          "pattern": "git branch -D ...",
          "pattern_type": "flag-argument-combination",
          "example": "git branch -D feature-branch",
          "match": {
            "flags_any": [
              "-D"
            ],
            "raw_pattern": "git\\s+branch\\b"
          }
        }
      ],
      "risk_tags": [
        "deletes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "notes": "Branch deletion removes a ref, not files on disk; however, it's treated as file deletion for schema consistency. Commits become unreachable rather than filesystem data being deleted.",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-rm-force",
      "description": "Forcefully removes files from the working tree and index, regardless of whether they have been committed.",
      "patterns": [
        {
          "pattern": "git rm -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "git rm -f file.txt",
          "match": {
            "flags_any": [
              "-f",
              "--force"
            ],
            "raw_pattern": "git\\s+rm\\b"
          }
        }
      ],
      "risk_tags": [
        "deletes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-checkout-force",
      "description": "Forces a checkout, overwriting local changes in files that would otherwise prevent the operation.",
      "patterns": [
        {
          "pattern": "git checkout -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "git checkout -f main",
          "match": {
            "flags_any": [
              "-f",
              "--force"
            ],
            "raw_pattern": "git\\s+checkout\\b"
          }
        },
        {
          "pattern": "git switch -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "git switch -f main",
          "match": {
            "flags_any": [
              "-f",
              "--force"
            ],
            "raw_pattern": "git\\s+switch\\b"
          }
        }
      ],
      "risk_tags": [
        "writes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-config-global",
      "description": "Modifies global git configuration, affecting all repositories for the user.",
      "patterns": [
        {
          "pattern": "git config --global ...",
          "pattern_type": "flag-argument-combination",
          "example": "git config --global user.name 'John Doe'",
          "match": {
            "flags_any": [
              "--global"
            ],
            "raw_pattern": "git\\s+config\\b"
          }
        }
      ],
      "risk_tags": [
        "modifies-environment"
      ],
      "reversible": "depends",
      "reversible_note": "Global config changes persist across all repositories and must be reverted manually.",
      "severity": "INFO",
      "notes": "T1574 (Hijack Execution Flow) applies specifically when the config key controls execution, such as core.gitProxy or credential.helper.",
      "mitre_attack": []
    },
    {
      "id": "git-config-global-unset",
      "description": "Removes global git configuration settings, which may break expected tool behavior or authentication across all repositories.",
      "patterns": [
        {
          "pattern": "git config --global --unset ...",
          "pattern_type": "flag-argument-combination",
          "example": "git config --global --unset user.name",
          "match": {
            "flags_all": [
              "--global",
              "--unset"
            ],
            "raw_pattern": "git\\s+config\\b"
          }
        },
        {
          "pattern": "git config --global --remove-section ...",
          "pattern_type": "flag-argument-combination",
          "example": "git config --global --remove-section user",
          "match": {
            "flags_all": [
              "--global",
              "--remove-section"
            ],
            "raw_pattern": "git\\s+config\\b"
          }
        }
      ],
      "risk_tags": [
        "modifies-environment"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "mitre_attack": []
    },
    {
      "id": "git-clone",
      "description": "Clones a remote repository to the local filesystem.",
      "patterns": [
        {
          "pattern": "git clone ...",
          "pattern_type": "argument",
          "example": "git clone https://github.com/user/repo",
          "match": {
            "raw_pattern": "git\\s+clone\\b"
          }
        }
      ],
      "risk_tags": [
        "network-egress",
        "writes-files"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "mitre_attack": [
        "T1105"
      ]
    },
    {
      "id": "git-push-standard",
      "description": "Pushes local commits to a remote repository without forcing.",
      "patterns": [
        {
          "pattern": "git push ...",
          "pattern_type": "argument",
          "example": "git push origin main",
          "match": {
            "raw_pattern": "git\\s+push\\b(?!.*(?:-f|--force))"
          }
        }
      ],
      "risk_tags": [
        "network-egress",
        "writes-files"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "mitre_attack": []
    },
    {
      "id": "git-fetch",
      "description": "Fetches data from a remote repository, updating remote-tracking branches.",
      "patterns": [
        {
          "pattern": "git fetch ...",
          "pattern_type": "argument",
          "example": "git fetch origin",
          "match": {
            "raw_pattern": "git\\s+fetch\\b"
          }
        }
      ],
      "risk_tags": [
        "network-egress",
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "mitre_attack": []
    },
    {
      "id": "git-pull",
      "description": "Fetches and incorporates changes from a remote repository into the working tree.",
      "patterns": [
        {
          "pattern": "git pull ...",
          "pattern_type": "argument",
          "example": "git pull origin main",
          "match": {
            "raw_pattern": "git\\s+pull\\b"
          }
        }
      ],
      "risk_tags": [
        "network-egress",
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "mitre_attack": [
        "T1105"
      ]
    },
    {
      "id": "git-rebase-interactive",
      "description": "Starts an interactive rebase to rewrite commit history, which can lead to data loss if commits are dropped or modified incorrectly.",
      "patterns": [
        {
          "pattern": "git rebase -i ...",
          "pattern_type": "flag-argument-combination",
          "example": "git rebase -i HEAD~3",
          "match": {
            "flags_any": [
              "-i",
              "--interactive"
            ],
            "raw_pattern": "git\\s+rebase\\b"
          }
        }
      ],
      "risk_tags": [
        "writes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-corruption"
      ],
      "reversible": "no",
      "severity": "WARNING",
      "mitre_attack": [
        "T1565.001"
      ]
    },
    {
      "id": "git-stash-drop",
      "description": "Removes the most recent stash entry permanently.",
      "patterns": [
        {
          "pattern": "git stash drop ...",
          "pattern_type": "argument",
          "example": "git stash drop",
          "match": {
            "raw_pattern": "git\\s+stash\\s+drop\\b"
          }
        }
      ],
      "risk_tags": [
        "deletes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    },
    {
      "id": "git-stash-clear",
      "description": "Removes all entries from the stash list permanently.",
      "patterns": [
        {
          "pattern": "git stash clear ...",
          "pattern_type": "argument",
          "example": "git stash clear",
          "match": {
            "raw_pattern": "git\\s+stash\\s+clear\\b"
          }
        }
      ],
      "risk_tags": [
        "deletes-files",
        "irreversible"
      ],
      "likely_consequences": [
        "data-loss"
      ],
      "reversible": "no",
      "severity": "ERROR",
      "mitre_attack": [
        "T1485"
      ]
    }
  ],
  "default_rule": {
    "risk_tags": [
      "reads-files"
    ],
    "reversible": "yes",
    "severity": "INFO"
  }
}
